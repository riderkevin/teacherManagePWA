{
  "name": "guitar-student-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "吉他教室 - 学生端小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
